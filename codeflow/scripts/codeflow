#!/bin/bash
# codeflow — single public entrypoint for the Codeflow skill
#
# This is intentionally thin: it routes subcommands to deterministic internal scripts.
# Breaking change: direct use of legacy scripts under scripts/ is no longer supported.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INTERNAL_DIR="$SCRIPT_DIR/_internal"
BIN_DIR="$INTERNAL_DIR/bin"
PY_DIR="$INTERNAL_DIR/py"

usage() {
  cat <<'EOF'
Usage:
  codeflow <command> [args...]

Commands:
  run       Run a relay session (dev-relay)
  guard     Guard operations: activate|deactivate|status|current
  control   Deterministic /codeflow soft-mode control router
  resume    Replay a previous session from its stream.jsonl
  review    PR review mode
  parallel  Parallel tasks mode
  bridge    Discord gateway bridge (optional)
  enforcer  Install/update/uninstall/status [--json] for the Codeflow enforcer plugin
  check     Developer checks (syntax + unit tests)
  smoke     Prereq/config smoke test

Examples:
  codeflow run -w ~/projects/app -- codex exec --json --full-auto 'fix tests'
  codeflow run -w ~/projects/app -- codex exec --json --full-auto - < prompt.txt
  codeflow run -w ~/projects/app -- claude -p --output-format stream-json --verbose < prompt.txt
  codeflow guard activate -P telegram --tg-chat <id> --tg-thread <topic_id_optional>
  codeflow guard current -P auto --session-key <openclaw_session_key>
  codeflow control --session-key <openclaw_session_key> --text '/codeflow status'
  codeflow resume -P telegram --tg-chat <id> /tmp/dev-relay.XXXXXX
  codeflow review -P discord https://github.com/org/repo/pull/123
  codeflow parallel -P discord tasks.txt
  codeflow enforcer install --restart
  codeflow enforcer status --json
EOF
}

require_internal() {
  local path="$1"
  if [ ! -e "$path" ]; then
    echo "❌ Error: internal component missing: $path" >&2
    echo "This Codeflow installation looks incomplete." >&2
    exit 2
  fi
}

is_help_arg() {
  case "${1:-}" in
    -h|--help|help) return 0 ;;
    *) return 1 ;;
  esac
}

guard_usage() {
  cat <<'EOF'
Usage:
  codeflow guard activate [run-flags]
  codeflow guard deactivate [run-flags]
  codeflow guard status [run-flags]
  codeflow guard current [--session-key <key>] [-P <platform|auto>]
EOF
}

resume_usage() {
  cat <<'EOF'
Usage:
  codeflow resume [run-flags] <relay_dir>
EOF
}

cmd="${1:-}"
case "$cmd" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;

  run)
    shift
    require_internal "$BIN_DIR/dev-relay.sh"
    if is_help_arg "${1:-}"; then
      exec bash "$BIN_DIR/dev-relay.sh" --help
    fi
    exec bash "$BIN_DIR/dev-relay.sh" "$@"
    ;;

  guard)
    shift || true
    action="${1:-}"
    shift || true
    require_internal "$BIN_DIR/dev-relay.sh"
    if [ -z "$action" ] || is_help_arg "$action"; then
      guard_usage
      exit 0
    fi
    case "$action" in
      activate)   exec bash "$BIN_DIR/dev-relay.sh" --activate "$@" ;;
      deactivate) exec bash "$BIN_DIR/dev-relay.sh" --deactivate "$@" ;;
      status)     exec bash "$BIN_DIR/dev-relay.sh" --guard-status "$@" ;;
      current)    require_internal "$BIN_DIR/guard-current.sh"; exec bash "$BIN_DIR/guard-current.sh" "$@" ;;
      *) echo "Error: unknown guard action '$action' (expected activate|deactivate|status|current)" >&2; guard_usage >&2; exit 2 ;;
    esac
    ;;

  control)
    shift || true
    require_internal "$PY_DIR/codeflow_skill_flow.py"
    exec env PYTHONPATH="$PY_DIR${PYTHONPATH:+:$PYTHONPATH}" python3 "$PY_DIR/codeflow_skill_flow.py" "$@"
    ;;

  resume)
    shift || true
    require_internal "$BIN_DIR/dev-relay.sh"
    if [ "$#" -eq 0 ]; then
      echo "Error: resume requires a relay directory" >&2
      resume_usage >&2
      exit 2
    fi
    if is_help_arg "${1:-}"; then
      resume_usage
      exit 0
    fi
    # Contract: relay dir must be the last argument; any flags must come before it.
    args=("$@")
    resume_dir="${args[$((${#args[@]} - 1))]}"
    unset 'args[$((${#args[@]} - 1))]'
    exec bash "$BIN_DIR/dev-relay.sh" "${args[@]}" --resume "$resume_dir"
    ;;

  review)
    shift
    require_internal "$BIN_DIR/review-pr.sh"
    if is_help_arg "${1:-}"; then
      exec bash "$BIN_DIR/review-pr.sh" --help
    fi
    exec bash "$BIN_DIR/review-pr.sh" "$@"
    ;;

  parallel)
    shift
    require_internal "$BIN_DIR/parallel-tasks.sh"
    if is_help_arg "${1:-}"; then
      exec bash "$BIN_DIR/parallel-tasks.sh" --help
    fi
    exec bash "$BIN_DIR/parallel-tasks.sh" "$@"
    ;;

  bridge)
    shift
    require_internal "$PY_DIR/discord-bridge.py"
    exec env PYTHONPATH="$PY_DIR${PYTHONPATH:+:$PYTHONPATH}" python3 "$PY_DIR/discord-bridge.py" "$@"
    ;;

  enforcer)
    shift || true
    require_internal "$BIN_DIR/enforcer.sh"
    if [ "$#" -eq 0 ] || is_help_arg "${1:-}"; then
      exec bash "$BIN_DIR/enforcer.sh" --help
    fi
    exec bash "$BIN_DIR/enforcer.sh" "$@"
    ;;

  check)
    shift
    require_internal "$BIN_DIR/check.sh"
    exec bash "$BIN_DIR/check.sh" "$@"
    ;;

  smoke)
    shift
    require_internal "$BIN_DIR/test-smoke.sh"
    exec bash "$BIN_DIR/test-smoke.sh" "$@"
    ;;

  *)
    echo "Error: unknown command '$cmd'" >&2
    usage >&2
    exit 2
    ;;
esac
